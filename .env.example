# .env.example
# Copy this file to .env and fill in real values for local development.
# In GitHub Actions, set these as repository secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloudflare (optional but needed for production) ───────────────────────────

# Base URL of your Cloudflare Worker (no trailing slash)
# e.g. https://linkedin-bot.your-account.workers.dev
CF_WORKER_URL=https://your-worker.workers.dev

# Bearer token to authenticate requests to the Worker
CF_WORKER_TOKEN=your_cloudflare_worker_token_here

# ── Runtime options ───────────────────────────────────────────────────────────

# Set to 1 to print posts to stdout without POSTing to Cloudflare
DRY_RUN=0

# Override date for BOE scraping (format: YYYYMMDD). Leave empty for today.
# BOE_DATE=20240601

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
